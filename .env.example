# Local Express API (optional; Vite proxies /tender*, /tenders)
# VITE_API_BASE=http://localhost:4000

# Skaftin (client-sdk) — required for auth + database client
# Use empty VITE_SKAFTIN_BASE_URL in dev so requests go through Vite proxy (same origin).
VITE_SKAFTIN_BASE_URL=
VITE_SKAFTIN_PROJECT_ID=
VITE_SKAFTIN_API_KEY=

# Optional: proxy target if not using default platform host
# VITE_SKAFTIN_PROXY_TARGET=https://skaftinplatform.bobosoftware.co.za
